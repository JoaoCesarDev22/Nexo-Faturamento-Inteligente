# NEXO - Faturamento Inteligente | Variáveis de ambiente
# COPIE este arquivo como `.env` e preencha os valores reais.
# NUNCA commite o `.env` no Git — apenas o `.env.example`.

# === Flask ===
FLASK_ENV=development
SECRET_KEY=trocar-isto-por-string-aleatoria-bem-grande-em-producao

# === Banco de dados ===
# Deixe vazio/comentado para usar SQLite local (instance/nexo_mvp.db) — não
# precisa de nenhuma conta externa para rodar o projeto.
# DATABASE_URL=sqlite:///instance/nexo_mvp.db

# Para PostgreSQL/Supabase em produção/homologação, preencha as duas:
#   DATABASE_URL -> conexão POOLED (PgBouncer, porta 6543) usada pela app em runtime.
#   DIRECT_URL   -> conexão DIRETA (porta 5432) usada para MIGRAÇÕES/DDL (Alembic).
# DATABASE_URL=postgresql://usuario:senha@host.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://usuario:senha@host.pooler.supabase.com:5432/postgres

# === Admin Master (seed inicial) ===
# Estas credenciais são lidas pelo seed.py para criar o primeiro ADMIN.
# Em PRODUÇÃO, troque imediatamente após o primeiro login.
ADMIN_EMAIL=admin@nexo.com.br
ADMIN_NOME=Administrador NEXO
ADMIN_SENHA=trocar-esta-senha-no-primeiro-deploy

# === Uploads ===
# Diretório onde arquivos enviados pelo admin serão armazenados.
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=20

# === Tempo real (Socket.IO) ===
# Origens permitidas no handshake do WebSocket, separadas por vírgula.
# Default já cobre o dev local — ajuste para o domínio real em produção.
SOCKETIO_CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# === Rate limiting (Flask-Limiter) ===
# memory:// é suficiente para uma única instância. Em produção com múltiplas
# instâncias, aponte para um Redis compartilhado (ex.: redis://host:6379).
RATELIMIT_STORAGE_URI=memory://

# === E-mail (SMTP / Flask-Mail) ===
# Preencha MAIL_USERNAME e MAIL_PASSWORD para ATIVAR o envio. Enquanto vazios,
# o sistema SUPRIME o envio (loga e segue) — nada quebra em dev/demo.
# Para Gmail: use uma SENHA DE APP (não a senha normal) com 2FA ativo.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# === IA (Claude / Anthropic) — geração automatizada da devolutiva ===
# Preencha ANTHROPIC_API_KEY (sk-ant-...) para ATIVAR a geração por IA.
# Vazio = fallback determinístico local (o sistema funciona, sem IA real).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# === NexoBot (suporte) — Hugging Face Inference (gratuito, opcional) ===
# Gere um token gratuito em huggingface.co/settings/tokens. Vazio = fallback local.
HF_API_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# === Servidor (opcional) ===
# HOST=127.0.0.1
# PORT=5000

# NEXO - Faturamento Inteligente | Variáveis de ambiente
# COPIE este arquivo como `.env` e preencha os valores reais.
# NUNCA commite o `.env` no Git — apenas o `.env.example`.

# === Flask ===
FLASK_ENV=development
SECRET_KEY=trocar-isto-por-string-aleatoria-bem-grande-em-producao

# === Banco de dados ===
# Caminho relativo à raiz do projeto. instance/ é o diretório padrão do Flask
# para arquivos persistentes (banco SQLite, uploads, etc).
DATABASE_URL=sqlite:///instance/nexo_mvp.db

# === Admin Master (seed inicial) ===
# Estas credenciais são lidas pelo seed.py para criar o primeiro ADMIN.
# Em PRODUÇÃO, troque imediatamente após o primeiro login.
ADMIN_EMAIL=admin@nexo.com.br
ADMIN_NOME=Administrador NEXO
ADMIN_SENHA=trocar-esta-senha-no-primeiro-deploy

# === Uploads ===
# Diretório onde arquivos enviados pelo admin serão armazenados.
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=20
